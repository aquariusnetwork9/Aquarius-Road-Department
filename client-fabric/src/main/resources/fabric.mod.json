{
  "schemaVersion": 1,
  "id": "ard",
  "version": "${version}",
  "name": "ARD — Highway Conditions",
  "description": "Crowdsourced nether-highway conditions: hazard-ahead HUD + optional report submission. Never transmits a raw coordinate -- an off-highway position is unrepresentable on the wire. See PROTOCOL.md.",
  "authors": [
    "aquariusnetwork9"
  ],
  "contact": {
    "sources": "https://github.com/aquariusnetwork9/highway-conditions",
    "homepage": "https://map.aquariusconnect.org"
  },
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.aquariusnetwork.highwayconditions.HighwayConditionsFabricClient"
    ]
  },
  "depends": {
    "java": ">=21",
    "minecraft": ["${mc_version}"],
    "fabricloader": ">=0.19.0",
    "fabric-api": "*"
  }
}
