# Discord application (developer.discord.com/applications) -- bot token, never commit the real value
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# The "Aquarius Road Dept" guild -- commands register instantly to one guild
# instead of waiting up to an hour for global propagation
DISCORD_GUILD_ID=
# Discord user IDs that can run /setup even without the Administrator permission
# (comma-separated), optional -- Administrator alone is normally enough
DISCORD_OWNER_IDS=

# The ARD ingest service this bot talks to (deployed separately, not in this repo)
ARD_BASE_URL=http://localhost:8788
# Shared first-party secret -- must match ARD_BOT_SECRET on the ARD server
# (PROTOCOL.md SS6.1, bot-complete). Generate with: openssl rand -hex 32
ARD_BOT_SECRET=
